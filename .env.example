# Get your API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# LangSmith observability (optional — tracing is off when LANGCHAIN_TRACING_V2 is unset)
# Get your API key at https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=viblabel

# Local SLM via Ollama (set USE_LOCAL_SLM=true to skip Gemini entirely)
USE_LOCAL_SLM=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision:11b
